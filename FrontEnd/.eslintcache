      className={className}\r\n    >\r\n      <Card id={id}>\r\n        <CardHeader\r\n          avatar={<Avatar color=\"primary\" aria-label=\"recipe\" />}\r\n          title={\r\n            <span style={{ color: \"#222\" }}>\r\n              {marketer_info.fname + \" \" + marketer_info.lname}\r\n            </span>\r\n          }\r\n          subheader={\r\n            <span style={{ fontSize: \".75rem\" }}>\r\n              {formatDate(data.created_date)}\r\n            </span>\r\n          }\r\n          action={\r\n            <div>\r\n              <IconButton\r\n                size=\"large\"\r\n                aria-label=\"account of current user\"\r\n                aria-controls=\"menu-appbar\"\r\n                aria-haspopup=\"true\"\r\n                onClick={handleMenu}\r\n                color=\"inherit\"\r\n              >\r\n                <MoreVertIcon />\r\n              </IconButton>\r\n              <Menu\r\n                id=\"menu-appbar\"\r\n                anchorEl={anchorEl}\r\n                anchorOrigin={{\r\n                  vertical: \"top\",\r\n                  horizontal: \"right\",\r\n                }}\r\n                keepMounted\r\n                transformOrigin={{\r\n                  vertical: \"top\",\r\n                  horizontal: \"right\",\r\n                }}\r\n                open={Boolean(anchorEl)}\r\n                onClose={handleClose}\r\n              >\r\n                <ReportProduct />\r\n              </Menu>\r\n            </div>\r\n          }\r\n        />\r\n        <PostContent text={data.product_text} />\r\n        {media}\r\n        <Stack\r\n          direction=\"row\"\r\n          justifyContent=\"space-evenly\"\r\n          alignItems=\"center\"\r\n        >\r\n          <Typography variant=\"body2\" marginLeft=\"1rem\" marginRight=\"auto\">\r\n            {!LikesCounter ? null : `${LikesCounter} Reaction`}\r\n          </Typography>\r\n          <Grid container width=\"fit-content\" marginLeft=\"auto\">\r\n            <Typography variant=\"body2\" marginRight=\".5rem\">\r\n              {!ReviewCounter ? null : `${ReviewCounter} Comments`}\r\n            </Typography>\r\n            <Typography variant=\"body2\" marginRight=\"1rem\">\r\n              {!ReviewCounter ? null : `${ReviewCounter} Shares`}\r\n            </Typography>\r\n          </Grid>\r\n        </Stack>\r\n\r\n        <Stack\r\n          direction=\"row\"\r\n          justifyContent=\"space-evenly\"\r\n          alignItems=\"center\"\r\n          spacing={5}\r\n        >\r\n          <Rating\r\n            defaultValue=\"1\"\r\n            precision=\".1\"\r\n            size=\"medium\"\r\n            name=\"read-only\"\r\n            value={RatingValue}\r\n            readOnly\r\n          />\r\n          <IconButton onClick={handleCommentClick}>\r\n            <MdOutlineRateReview />\r\n          </IconButton>\r\n        </Stack>\r\n        <Reviews open={openComment} product_id={data.id} />\r\n      </Card>\r\n    </Paper>\r\n  );\r\n};\r\n\r\nexport default Product;\r\n","F:\\Projects under development\\MYAO_project\\myao\\FrontEnd\\src\\components\\Post\\Reviews.js",[],"F:\\Projects under development\\MYAO_project\\myao\\FrontEnd\\src\\components\\Post\\ReportProduct.js",["455","456"],"import * as React from 'react';\r\nimport Box from '@mui/material/Box';\r\nimport {  Button, MenuItem, Modal, Paper, Radio, RadioGroup, Stack, TextField, Typography } from '@mui/material';\r\nimport FormControlLabel from '@mui/material/FormControlLabel';\r\nimport { BsFillArrowRightCircleFill } from \"react-icons/bs\";\r\n\r\nconst ReportProduct = () => {\r\nconst [value, setValue] = React.useState('Controlled');\r\nconst [openReport, setopenReport] = React.useState(0);\r\n\r\n    const stylerep = {\r\n    position: 'absolute',\r\n    top: '50%',\r\n    left: '50%',\r\n    transform: 'translate(-50%, -50%)',\r\n    bgcolor: 'background.paper',\r\n    borderRadius: '16px',\r\n    boxShadow: 50,\r