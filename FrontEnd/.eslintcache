}}>\r\n              {formatDate(data.created_date)}\r\n            </span>\r\n          }\r\n          action={\r\n            <div>\r\n              <IconButton\r\n                size=\"medium\"\r\n                aria-label=\"delete this post\"\r\n                aria-haspopup=\"true\"\r\n                onClick={() => handleBlock(index, data, 0)}\r\n                color=\"inherit\"\r\n              >\r\n                <BsHandThumbsUpFill style={{ color: \"#aaa\" }} />\r\n              </IconButton>\r\n              <IconButton\r\n                size=\"medium\"\r\n                aria-label=\"delete this post\"\r\n                aria-haspopup=\"true\"\r\n                onClick={() => handleBlock(index, data, 1)}\r\n                color=\"inherit\"\r\n              >\r\n                <IoHandRightSharp style={{ color: \"#aaa\" }} />\r\n              </IconButton>\r\n            </div>\r\n          }\r\n        />\r\n        <PostContent text={data.product_text} style={{ minHeight: \"1rem\" }} />\r\n\r\n        {/* <Box style={{ marginLeft: \"1rem\" }}>\r\n          <Typography\r\n            variant=\"body2\"\r\n            sx={{ fontSize: \"1.3rem\", fontWeight: \"500\" }}\r\n          >\r\n            Report reason\r\n          </Typography>\r\n          <Typography\r\n            variant=\"h6\"\r\n            sx={{ fontSize: \"1rem\", color: theme.palette.warning.main }}\r\n          >\r\n            this report becaue its not good\r\n          </Typography>\r\n        </Box> */}\r\n\r\n        {media}\r\n      </Card>\r\n    </Paper>\r\n  );\r\n};\r\n\r\nexport default AdminReportProduct;\r\n","F:\\Projects under development\\MYAO_project\\myao\\FrontEnd\\src\\components\\Post\\Create_post.js",[],"F:\\Projects under development\\MYAO_project\\myao\\FrontEnd\\src\\components\\Post\\PostButton.js",[],"F:\\Projects under development\\MYAO_project\\myao\\FrontEnd\\src\\components\\Post\\PopPostStyle.js",[],"F:\\Projects under development\\MYAO_project\\mya