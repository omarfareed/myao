ial/Box';\r\nimport {  Button, MenuItem, Modal, Paper, Radio, RadioGroup, Stack, TextField, Typography } from '@mui/material';\r\nimport FormControlLabel from '@mui/material/FormControlLabel';\r\nimport { BsFillArrowRightCircleFill } from \"react-icons/bs\";\r\n\r\nconst ReportPost = () => {\r\nconst [value, setValue] = React.useState('Controlled');\r\nconst [openReport, setopenReport] = React.useState(0);\r\n\r\n    const stylerep = {\r\n    position: 'absolute',\r\n    top: '50%',\r\n    left: '50%',\r\n    transform: 'translate(-50%, -50%)',\r\n    bgcolor: 'background.paper',\r\n    borderRadius: '16px',\r\n    boxShadow: 50,\r\n    p:1,\r\n    width: {\r\n    xs: \"90%\", \r\n    sm: \"60%\", \r\n    md: \"40%\"\r\n}\r\n  };\r\n\r\n  return (<React.Fragment>\r\n    <MenuItem onClick={ ()=>{setopenReport(1);} } >\r\n    report\r\n    </MenuItem>\r\n<Modal\r\n        open={openReport}\r\n        onClose={ ()=>{ setopenReport(0);} }\r\n      >\r\n        <Paper sx={stylerep} >\r\n\r\n            <Box sx={{ p: 2, borderTop: '3px solid blue' , borderRadius : '16px' }} >\r\n                <Typography align='left' variant='h6' > Report Post </Typography>\r\n            </Box>\r\n            <Typography align='left' variant='caption' sx={{display: { xs: 'block', md: 'none' } }} > Please Choice what is the type of report  </Typography>\r\n            <Typography align='left' variant='h6' sx={{display: { xs: 'none', md: 'block' } }} > Please Choice what is the type of report  </Typography>\r\n\r\n            <Stack \r\n            direction=\"column\"\r\n            justifyContent=\"center\"\r\n            alignItems=\"left\"\r\n            spacing={2}\r\n            sx={{ p: 2, borderBottom: '3px solid blue' , borderRadius : '16px' }}\r\n            >\r\n            <RadioGroup name=\"use-radio-group\" defaultValue=\"first\">\r\n            <FormControlLabel value=\"first\" label=\"first reason\" control={<Radio />} />\r\n            <FormControlLabel value=\"second\" label=\"Second reason\" control={<Radio />} />\r\n            <FormControlLabel value=\"third\" label=\"third reason\" control={<Radio />} />\r\n            <FormControlLabel value=\"Forth\" label=\"forth reason\" control={<Radio />} />\r\n            <FormControlLabel value=\"Fifth\" label=\"Fifth reason\" control={<Radio />} />\r\n            </RadioGroup>\r\n           \r\n            <Stack\r\n            direction=\"row\"\r\n            justifyContent=\"left\"\r\n            alignItems=\"left\"\r\n            spacing={1}\r\n            >\r\n            <TextField\r\n            label=\"Report\"\r\n            placeholder=\"Explain your report\"\r\n            multiline\r\n            variant=\"standard\"\r\n            />\r\n            <Button variant=\"text\" centerRipple size=\"medium\" startIcon={<BsFillArrowRightCircleFill />} />\r\n            </Stack>\r\n\r\n\r\n            </Stack>\r\n\r\n\r\n        </Paper>\r\n\r\n      </Modal>\r\n      </React.Fragment>\r\n  );\r\n}\r\n\r\nexport default ReportPost;","F:\\Projects under development\\MYAO\\FrontEnd\\src\\components\\Post\\PostContent.js",["452","453","454","455"],"import React, { Component } from \"react\";\r\nimport Accordion from \"@mui/material/Accordion\";\r\nimport AccordionSummary from \"@mui/material/AccordionSummary\";\r\nimport AccordionDetails from \"@mui/material/AccordionDetails\";\r\nimport Typography from \"@mui/material/Typography\";\r\nimport { CardContent } from \"@mui/material\";\r\nimport ShowMoreText from \"react-show-more-text\";\r\nimport { MdExpandMore, MdExpandLess } from \"react-icons/md\";\r\n\r\nconst PostContent = ({ text }) => {\r\n  return (\r\n    <CardContent sx={{ padding: \"1rem\", minHeight: \"2rem\" }}>\r\n      <ShowMoreText\r\n        lines={3}\r\n        more={<MdExpandMore title=\"Show More\" />}\r\n        less={<MdExpandLess title=\"Show Less\" />}\r\n        className=\"content-css\"\r\n        anchorClass=\"my-anchor-css-class\"\r\n        expanded={false}\r\n      >\r\n        <Typography>{text}</Typography>\r\n      </ShowMoreText>\r\n    </CardContent>\r\n  );\r\n};\r\n\r\nexport default PostContent;\r\n","F:\\Projects under development\\MYAO\\FrontEnd\\src\\components\\Post\\Comments.js",["456","457"],"F:\\Projects under development\\MYAO\\FrontEnd\\src\\components\\Post\\imgGallary.js",[],"F:\\Projects under development\\MYAO\\FrontEnd\\src\\pages\\Home\\MediumSection.js",[],"F:\\Projects under development\\MYAO\\FrontEnd\\src\\pages\\GlobalForAll\\GetPosts.js",["458","459","460"],"F:\\Projects under development\\MYAO_project\\myao\\FrontEnd\\src\\index.js",[],["461","462"],"F:\\Projects under development\\MYAO_project\\myao\\FrontEnd\\src\\App.js",["463"],"import SignIn from \"./pages/Sign/SignIn\";\r\nimport { Route, Switch, useHistory, useLocation } from \"react-router-dom\";\r\nimport SignUp from \"./pages/Sign/SignUp\";\r\nimport MainPage from \"./pages/Home/MainPage\";\r\nimport SettingPage from \"./pages/SettingPage/settingPage\";\r\nimport ProfilePage from \"./pages/Profile/ProfilePage\";\r\nimport Header from \"./components/Header/header\";\r\nimport MarketerPage from \"./pages/Marketer/marketerProfile\";\r\nimport getMe from \"./Store/Thunk/getMe\";\r\nimport { useDispatch, useSelector } from \"react-redux\";\r\n\r\nimport { useEffect } from \"react\";\r\nimport SearchPage from \"./pages/SearchPage/SearchPage\";\r\nimport FriendRequestPage from \"./pages/FriendRequests/FriendRequestPage\";\r\nimport FavPosts from \"./pages/favPosts/favPosts\";\r\nimport ReportedSurf from \"./pages/ReportedSurf/ReportedSurf\";\r\nimport ReportedMar from \"./pages/ReportedSurf/ReportedMark\";\r\nimport ReportedPost from \"./pages/ReportedSurf/ReportedPosts\";\r\nimport ReportedProduct from \"./pages/ReportedSurf/ReportedProduct\";\r\nfunction App() {\r\n  const dispatch = useDispatch();\r\n  const history = useHistory();\r\n  const location = useLocation();\r\n  const loadingUser = useSelector((state) => state.reducer.loadingUser);\r\n  const { isAuth, user } = useSelector((state) => state.reducer);\r\n  useEffect(() => {\r\n    dispatch(getMe());\r\n  }, [dispatch]);\r\n  useEffect(() => {\r\n    const locationPath = location.pathname;\r\n    if (!loadingUser)\r\n      if (\r\n        isAuth &&\r\n        (locationPath.includes(\"/login\") || locationPath.includes(\"/signup\"))\r\n      ) {\r\n        if (user.role === \"marketer\") history.push(`/marketer/${user.id}`);\r\n        else if (user.role === \"admin\") history.push(\"/admin/surfers\");\r\n        else history.push(\"/\");\r\n      } else if (\r\n        !isAuth &&\r\n        !locationPath.includes(\"/login\") &&\r\n        !locationPath.includes(\"/signup\")\r\n      )\r\n        history.push(\"/login\");\r\n      else {\r\n        if (\r\n          user.role === \"marketer\" &&\r\n          (locationPath === \"/\" || locationPath.includes(\"admin\"))\r\n        )\r\n          history.push(`/marketer/${user.id}`);\r\n        else if (user.role === \"surfer\" && locationPath.includes(\"admin\"))\r\n          history.push(\"/\");\r\n        // else if (user.role === \"admin\") history.push(\"/admin/surfer\");\r\n      }\r\n  }, [history, isAuth, loadingUser, location.pathname]);\r\n  return (\r\n    <>\r\n      {loadingUser ? null : (\r\n        <>\r\n          <Header />\r\n          <Switch>\r\n            <Route path=\"/\" exact>\r\n              <MainPage />\r\n            </Route>\r\n            <Route path=\"/login\">\r\n              <SignIn />\r\n            </Route>\r\n            <Route path=\"/signup\">\r\n              <SignUp />\r\n            </Route>\r\n            <Route path=\"/setting\">\r\n              <SettingPage />\r\n            </Route>\r\n            <Route path=\"/marketer/:id\">\r\n              <MarketerPage />\r\n            </Route>\r\n            <Route path=\"/search/:search\">\r\n              <SearchPage />\r\n            </Route>\r\n            <Route path=\"/profile/:id\">\r\n              <ProfilePage />\r\n            </Route>\r\n            <Route path=\"/fav\">\r\n              <FavPosts />\r\n            </Route>\r\n            <Route path=\"/requests\">\r\n              <FriendRequestPage />\r\n            </Route>\r\n            <Route path=\"/admin/surfers\">\r\n              <ReportedSurf />\r\n            </Route>\r\n            <Route path=\"/admin/marketers\">\r\n              <ReportedMar />\r\n            </Route>\r\n            <Route path=\"/admin/posts\">\r\n              <ReportedPost />\r\n            </Route>\r\n            <Route path=\"/admin/products\">\r\n              <ReportedProduct />\r\n            </Route>\r\n          </Switch>\r\n        </>\r\n      )}\r\n    </>\r\n  );\r\n}\r\n\r\nexport default App;\r\n","F:\\Projects under development\\MYAO_project\\myao\\FrontEnd\\src\\Utilities\\Theme.js",[],"F:\\Projects under development\\MYAO_project\\myao\\FrontEnd\\src\\Store\\Store.js",[],"F:\\Projects under development\\MYAO_project\\myao\\FrontEnd\\src\\Store\\UserSlice.js",[],"F:\\Projects under development\\MYAO_project\\myao\\FrontEnd\\src\\Store\\Thunk\\getMe.js",[],"F:\\Projects under development\\MYAO_project\\myao\\FrontEnd\\src\\pages\\Sign\\SignIn.js",[],"F:\\Projects under development\\MYAO_project\\myao\\FrontEnd\\src\\pages\\Sign\\SignUp.js",[],"F:\\Projects under development\\MYAO_project\\myao\\FrontEnd\\src\\pages\\Home\\MainPage.js",[],"F:\\Projects under development\\MYAO_project\\myao\\FrontEnd\\src\\pages\\SettingPage\\settingPage.js",[],"F:\\Projects under development\\MYAO_project\\myao\\FrontEnd\\src\\pages\\SearchPage\\SearchPage.js",[],"F:\\Projects under development\\MYAO_project\\myao\\FrontEnd\\src\\pages\\Profile\\ProfilePage.js",["464"],"import {\r\n  Avatar,\r\n  Grid,\r\n  IconButton,\r\n  Paper,\r\n  Typography,\r\n  useTheme,\r\n} from \"@mui/material\";\r\nimport { SiAdblock } from \"react-icons/si\";\r\nimport useStyle from \"./ProfileStyle\";\r\nimport LeftSection from \"./LeftSection\";\r\nimport GetPosts from \"../GlobalForAll/GetPosts\";\r\nimport { useParams } from \"react-router-dom\";\r\nimport { useEffect, useState } from \"react\";\r\nimport { useSelector } from \"react-redux\";\r\nimport FriendSectionButton from \"./firstSectionButton\";\r\nimport axios from \"axios\";\r\nconst ProfilePage = () => {\r\n  const classes = useStyle();\r\n  const { user } = useSelector((state) => state.reducer);\r\n  const [profileUser, setProfileUser] = useState(user);\r\n  const params = useParams();\r\n  const Theme = useTheme();\r\n  useEffect(() => {\r\n    const fetchingFunc = async () => {\r\n      const { data } = await axios.get(`/api/v1/surfer/${params.id}`);\r\n      setProfileUser(data.data[0]);\r\n    };\r\n    try {\r\n      if (user.id !== params.id) {\r\n        fetchingFunc();\r\n      }\r\n    } catch (err) {\r\n      alert(err.message);\r\n    }\r\n    // eslint-disable-next-line react-hooks/exhaustive-deps\r\n  }, [params.id]);\r\n  // useEffect(() => {\r\n  //   let leftSectionElement = document.getElementById(\"leftSectionProfile\");\r\n\r\n  //   document.addEventListener(\"scroll\", () => {\r\n  //     if (window.innerWidth >= Theme.breakpoints.values.lg) {\r\n  //       if (window.scrollY > 806.4000244140625) {\r\n  //         leftSectionElement.style.position = \"fixed\";\r\n  //         leftSectionElement.style.bottom = \"0\";\r\n  //       } else if (window.scrollY < 806.4000244140625) {\r\n  //         leftSectionElement.style.position = \"relative\";\r\n  //       }\r\n  //     }\r\n  //   });\r\n  //   // eslint-disable-next-line react-hooks/exhaustive-deps\r\n  // }, []);\r\n  const handleBlock = async () => {\r\n    await axios.patch(`/api/v1/surfer/${params.id}`, {\r\n      is_active: 0,\r\n    });\r\n  };\r\n  return (\r\n    <Grid container className={classes.page} direction=\"column\">\r\n      <Paper className={classes.imageSection} elevation={3}>\r\n        <Grid container className={classes.secondImage}>\r\n          {profileUser.cover_photo && (\r\n            <img\r\n              alt=\"coverimage\"\r\n              src={profileUser.cover_photo}\r\n              style={{ width: \"100%\", height: \"100%\" }}\r\n            />\r\n          )}\r\n          <Grid\r\n            container\r\n            className={classes.cover}\r\n            justifyContent=\"center\"\r\n            alignItems=\"center\"\r\n          >\r\n            <Avatar\r\n              sx={{ width: \"95%\", height: \"95%\" }}\r\n              src={profileUser.photo}\r\n            ></Avatar>\r\n          </Grid>\r\n        </Grid>\r\n\r\n        <Typography variant=\"h2\" className={classes.personName}>\r\n          {`${profileUser.fname} ${profileUser.lname}`}{\" \"}\r\n          {user.role === \"admin\" && (\r\n            <IconButton size=\"large\">\r\n              <SiAdblock style={{ fontSize: \"2rem\" }} onClick={handleBlock} />\r\n            </IconButton>\r\n          )}\r\n        </Typography>\r\n        <Typography variant=\"subtitle1\" className={classes.role}>\r\n          {profileUser.jop && `${profileUser.jop}`}\r\n        </Typography>\r\n        <Typography variant=\"subtitle1\" className={classes.address}>\r\n          {profileUser.address && `${profileUser.address}`}\r\n        </Typography>\r\n        {params.id !== user.id && user.role === \"surfer\" && (\r\n          <FriendSectionButton source_id={user.id} target_id={params.id} />\r\n        )}\r\n      </Paper>\r\n      <Grid container>\r\n        <Grid item sm={12} lg={5} style={{ height: \"fit-content\" }}>\r\n          <LeftSection user={user} />\r\n        </Grid>\r\n        <Grid container className={classes.rightSection} item lg={7}>\r\n          <Grid container style={{ height: \"fit-content\" }}>\r\n            <GetPosts\r\n              className={classes.post}\r\n              linkOfFetching={`/api/v1/surfer/${params.id}/post`}\r\n            />\r\n            <div style={{ height: \"1rem\", width: \"100%\" }}></div>\r\n          </Grid>\r\n        </Grid>\r\n      </Grid>\r\n    </Grid>\r\n  );\r\n};\r\n\r\nexport default ProfilePage;\r\n","F:\\Projects under development\\MYAO_project\\myao\\FrontEnd\\src\\pages\\Marketer\\marketerProfile.js",[],"F:\\Projects under development\\MYAO_project\\myao\\FrontEnd\\src\\components\\Header\\header.js",[],"F:\\Projects under development\\MYAO_project\\myao\\FrontEnd\\src\\pages\\Sign\\SignStyle.js",[],"F:\\Projects under development\\MYAO_project\\myao\\FrontEnd\\src\\Utilities\\ParsingDate.js",[],"F:\\Projects under development\\MYAO_project\\myao\\FrontEnd\\src\\pages\\Home\\MediumSection.js",[],"F:\\Projects under development\\MYAO_project\\myao\\FrontEnd\\src\\pages\\Home\\leftSection.js",["465","466"],"import { Avatar, Grid, Paper, Typography } from \"@mui/material\";\r\nimport useStyle from \"./HomeStyle\";\r\nimport { useSelector } from \"react-redux\";\r\nimport SurferCard from \"../../components/surferCard/surferCard\";\r\nconst LeftSection = () => {\r\n  const classes = useStyle();\r\n  const { user } = useSelector((state) => state.reducer);\r\n  return (\r\n    <>\r\n      <Grid container justifyContent=\"flex-end\">\r\n        <Grid item className={classes.LeftSection}>\r\n          <SurferCard\r\n            user={user}\r\n            newThings={\r\n              <Typography variant=\"subtitle1\" className={classes.margin}>\r\n                {user.job ? user.job : \"NO RULE SPECIFIED\"}\r\n              </Typography>\r\n            }\r\n          />\r\n        </Grid>\r\n        {/* <Paper className={classes.LeftSection}>\r\n          <Grid container direction=\"column\" alignItems=\"center\">\r\n            <Grid\r\n              container\r\n              justifyContent=\"center\"\r\n              className={classes.avatarContainer}\r\n            >\r\n              <Avatar src={user.photo} className={classes.avatarleft} />\r\n            </Grid>\r\n            <Typography\r\n              variant=\"h5\"\r\n              className={`${classes.nameLeft} ${classes.margin}`}\r\n            >\r\n              {user.fname + \" \" + user.lname}\r\n            </Typography>\r\n            <Typography variant=\"subtitle1\" className={classes.margin}>\r\n              {user.job ? user.job : \"NO RULE SPECIFIED\"}\r\n            </Typography>\r\n          </Grid>\r\n        </Paper> */}\r\n      </Grid>\r\n    </>\r\n  );\r\n};\r\nexport default LeftSection;\r\n","F:\\Projects under development\\MYAO_project\\myao\\FrontEnd\\src\\pages\\SettingPage\\settingStyle.js",[],"F:\\Projects under development\\MYAO_project\\myao\\FrontEnd\\src\\pages\\Profile\\ProfileStyle.js",[],"F:\\Projects under development\\MYAO_project\\myao\\FrontEnd\\src\\pages\\SearchPage\\SearchPageStyle.js",[],"F:\\Projects under development\\MYAO_project\\myao\\FrontEnd\\src\\pages\\Profile\\LeftSection.js",[],"F:\\Projects under development\\MYAO_project\\myao\\FrontEnd\\src\\components\\Header\\HeaderStyle.js",[],"F:\\Projects under development\\MYAO_project\\myao\\FrontEnd\\src\\pages\\Marketer\\marketerStyle.js",[],"F:\\Projects under development\\MYAO_project\\myao\\FrontEnd\\src\\components\\InputField.js\\InputField.js",[],"F:\\Projects under development\\MYAO_project\\myao\\FrontEnd\\src\\components\\AvatarImage\\AvatarImage.js",[],"F:\\Projects under development\\MYAO_project\\myao\\FrontEnd\\src\\components\\PopUp\\PopPost.js",[],["467","468"],"F:\\Projects under development\\MYAO_project\\myao\\FrontEnd\\src\\components\\surferCard\\surferCard.js",[],"F:\\Projects under development\\MYAO_project\\myao\\FrontEnd\\src\\pages\\GlobalForAll\\GetPosts.js",[],"F:\\Projects under development\\MYAO_project\\myao\\FrontEnd\\src\\pages\\Home\\HomeStyle.js",[],"F:\\Projects under development\\MYAO_project\\myao\\FrontEnd\\src\\pages\\Profile\\FriendCard.js",[],"F:\\Projects under development\\MYAO_project\\myao\\FrontEnd\\src\\components\\AvatarImage\\AvatarStyle.js",[],"F:\\Projects under development\\MYAO_project\\myao\\FrontEnd\\src\\components\\PopUp\\UploadButton.js",[],"F:\\Projects under development\\MYAO_project\\myao\\FrontEnd\\src\\components\\PopUp\\PopPostStyle.js",[],"F:\\Projects under development\\MYAO_project\\myao\\FrontEnd\\src\\components\\PopUp\\PostButton.js",[],"F:\\Projects under development\\MYAO_project\\myao\\FrontEnd\\src\\components\\Post\\post.js",[],"F:\\Projects under development\\MYAO_project\\myao\\FrontEnd\\src\\components\\Post\\imgGallary.js",[],"F:\\Projects under development\\MYAO_project\\myao\\FrontEnd\\src\\components\\Post\\Comments.js",[],"F:\\Projects under development\\MYAO_project\\myao\\FrontEnd\\src\\components\\Post\\ReportPost.js",[],"F:\\Projects under development\\MYAO_project\\myao\\FrontEnd\\src\\components\\Post\\PostContent.js",[],"F:\\Projects under development\\MYAO_project\\myao\\FrontEnd\\src\\components\\Post\\ImgSlider.js",[],"F:\\Projects under development\\MYAO_project\\myao\\FrontEnd\\src\\components\\Post\\imgSliderStyles.js",[],"F:\\Projects under development\\MYAO_project\\myao\\FrontEnd\\src\\components\\Wrapper\\Wrapper.js",[],"F:\\Projects under development\\MYAO_project\\myao\\FrontEnd\\src\\pages\\FriendRequests\\FriendRequestPage.js",[],"F:\\Projects under development\\MYAO_project\\myao\\FrontEnd\\src\\pages\\Profile\\firstSectionButton.js",["469"],"import { Button, Grid } from \"@mui/material\";\r\nimport axios from \"axios\";\r\nimport { useEffect, useState } from \"react\";\r\nimport { HiUserAdd, HiUserRemove } from \"react-icons/hi\";\r\nimport { MdOutlineReport } from \"react-icons/md\";\r\nimport { FaUserCheck } from \"react-icons/fa\";\r\nimport useStyle from \"./ProfileStyle\";\r\nimport ReportPost from \"../../components/Post/ReportPost\";\r\nimport parseDateF from \"../../Utilities/ParsingDate\";\r\nconst FriendSectionButton = ({ source_id, target_id }) => {\r\n  const classes = useStyle();\r\n  const [condition, setCondition] = useState(0);\r\n  // 0 => no relation  // 2 => already a friend  // 4 => sent from // 1 => waiting for accepting\r\n  useEffect(() => {\r\n    const asyncFunc = async () => {\r\n      const { data } = await axios.patch(\"/api/v1/friend\", { target_id });\r\n      setCondition(data.data.type);\r\n    };\r\n    asyncFunc();\r\n  }, [target_id]); // get type of the relation\r\n\r\n  const addFriend = async () => {\r\n    await axios.post(\"/api/v1/friend\", { source_id, target_id });\r\n    setCondition(1);\r\n  };\r\n  const noRelation = async () => {\r\n    await axios.put(\"/api/v1/friend\", { target_id });\r\n    setCondition(0);\r\n  };\r\n  const acceptRequest = async () => {\r\n    try {\r\n      await axios.post(\"/api/v1/friend/accept\", {\r\n        friendship_time: parseDateF(Date.now()),\r\n        source_id: target_id,\r\n      });\r\n      setCondition(2);\r\n    } catch (err) {\r\n      alert(err.message);\r\n    }\r\n  };\r\n  return (\r\n    <>\r\n      {condition === 2 ? (\r\n        <Button\r\n          variant=\"contained\"\r\n          className={classes.AddButton}\r\n          onClick={noRelation}\r\n        >\r\n          <HiUserRemove style={{ marginRight: \"8px\", fontSize: \"1.2rem\" }} />{\" \"}\r\n          Unfriend\r\n        </Button>\r\n      ) : condition === 4 ? (\r\n        <Button\r\n          variant=\"contained\"\r\n          className={classes.AddButton}\r\n          onClick={acceptRequest}\r\n        >\r\n          <FaUserCheck style={{ marginRight: \"8px\", fontSize: \"1.2rem\" }} />\r\n          Confirm Request\r\n        </Button>\r\n      ) : condition === 1 ? (\r\n        <Button\r\n          variant=\"contained\"\r\n          className={classes.AddButton}\r\n          onClick={noRelation}\r\n        >\r\n          <HiUserRemove style={{ marginRight: \"6px\", fontSize: \"1.2rem\" }} />\r\n          Undo Requesting\r\n        </Button>\r\n      ) : (\r\n        <Button\r\n          variant=\"contained\"\r\n          className={classes.AddButton}\r\n          onClick={addFriend}\r\n        >\r\n          <HiUserAdd style={{ marginRight: \"6px\", fontSize: \"1.2rem\" }} /> Add\r\n          Friend\r\n        </Button>\r\n      )}\r\n      <ReportPost\r\n        is_post={0}\r\n        reported_id={target_id}\r\n        myButton={\r\n          <Button\r\n            variant=\"outlined\"\r\n            className={`${classes.AddButton} ${classes.reportButton}`}\r\n          >\r\n            <MdOutlineReport style={{ fontSize: \"1.3rem\" }} />\r\n            Report\r\n          </Button>\r\n        }\r\n      ></ReportPost>\r\n    </>\r\n  );\r\n};\r\nexport default FriendSectionButton;\r\n","F:\\Projects under development\\MYAO_project\\myao\\FrontEnd\\src\\components\\emptyScreen\\NoFriendReq.js",[],"F:\\Projects under development\\MYAO_project\\myao\\FrontEnd\\src\\pages\\favPosts\\favPosts.js",[],"F:\\Projects under development\\MYAO_project\\myao\\FrontEnd\\src\\pages\\GlobalForAll\\GetProducts.js",[],"F:\\Projects under development\\MYAO_project\\myao\\FrontEnd\\src\\components\\Post\\Product.js",["470","471"],"import * as React from \"react\";\r\nimport Card from \"@mui/material/Card\";\r\nimport CardHeader from \"@mui/material/CardHeader\";\r\nimport Avatar from \"@mui/material/Avatar\";\r\nimport IconButton from \"@mui/material/IconButton\";\r\nimport Typography from \"@mui/material/Typography\";\r\nimport { Grid, Menu, Paper, Stack } from \"@mui/material\";\r\nimport Rating from \"@mui/material/Rating\";\r\nimport ReportProduct from \"./ReportProduct\";\r\nimport PostContent from \"./PostContent\";\r\nimport PostImgs from \"./imgGallary\";\r\nimport { MdOutlineRateReview } from \"react-icons/md\";\r\nimport { FiMoreVertical as MoreVertIcon } from \"react-icons/fi\";\r\nimport Reviews from \"./Reviews\";\r\n\r\nconst formatDate = (created_date) => {\r\n  let date = new Date(created_date);\r\n  return date.toUTCString().slice(0, 16);\r\n};\r\n\r\nconst Product = ({ id, marketer_info = {}, data, className, style = {} }) => {\r\n  const LikesCounter = data.like_counter;\r\n  const ReviewCounter = data.Review_counter;\r\n  const media =\r\n    data.media.length > 0 ? <PostImgs photos={data.media} /> : <></>;\r\n\r\n  const [anchorEl, setAnchorEl] = React.useState(null);\r\n  const [RatingValue, setRatingValue] = React.useState(data.avg_rating);\r\n\r\n  const handleMenu = (event) => {\r\n    setAnchorEl(event.currentTarget);\r\n  };\r\n\r\n  const handleClose = () => {\r\n    setAnchorEl(null);\r\n  };\r\n  const label = { inputProps: { \"aria-label\": \"Checkbox demo\" } };\r\n\r\n  const [openComment, setOpenComment] = React.useState(0);\r\n  const handleCommentClick = () => {\r\n    setOpenComment(!openComment);\r\n  };\r\n\r\n  return (\r\n    <Paper\r\n      style={{ width: \"100%\", height: \"fit-content\", ...style }}\r\n      className={className}\r\n    >\r\n      <Card id={id}>\r\n        <CardHeader\r\n          avatar={<Avatar color=\"primary\" aria-label=\"recipe\" />}\r\n          title={\r\n            <span style={{ color: \"#222\" }}>\r\n              {marketer_info.fname + \" \" + marketer_info.lname}\r\n            </span>\r\n          }\r\n          subheader={\r\n            <span style={{ fontSize: \".75rem\" }}>\r\n              {formatDate(data.created_date)}\r\n            </span>\r\n          }\r\n          action={\r\n            <div>\r\n              <IconButton\r\n                size=\"large\"\r\n                aria-label=\"account of current user\"\r\n                aria-controls=\"menu-appbar\"\r\n                aria-haspopup=\"true\"\r\n                onClick={handleMenu}\r\n                color=\"inherit\"\r\n              >\r\n                <MoreVertIcon />\r\n              </IconButton>\r\n              <Menu\r\n                id=\"menu-appbar\"\r\n                anchorEl={anchorEl}\r\n                anchorOrigin={{\r\n                  vertical: \"top\",\r\n                  horizontal: \"right\",\r\n                }}\r\n                keepMounted\r\n                transformOrigin={{\r\n                  vertical: \"top\",\r\n                  horizontal: \"right\",\r\n                }}\r\n                open={Boolean(anchorEl)}\r\n                onClose={handleClose}\r\n              >\r\n                <ReportProduct />\r\n              </Menu>\r\n            </div>\r\n          }\r\n        />\r\n        <PostContent text={data.product_text} />\r\n        {media}\r\n        <Stack\r\n          direction=\"row\"\r\n          justifyContent=\"space-evenly\"\r\n          alignItems=\"center\"\r\n        >\r\n          <Typography variant=\"body2\" marginLeft=\"1rem\" marginRight=\"auto\">\r\n            {!LikesCounter ? null : `${LikesCounter} Reaction`}\r\n          </Typography>\r\n          <Grid container width=\"fit-content\" marginLeft=\"auto\">\r\n            <Typography variant=\"body2\" marginRight=\".5rem\">\r\n              {!ReviewCounter ? null : `${ReviewCounter} Comments`}\r\n            </Typography>\r\n            <Typography variant=\"body2\" marginRight=\"1rem\">\r\n              {!ReviewCounter ? null : `${ReviewCounter} Shares`}\r\n            </Typography>\r\n          </Grid>\r\n        </Stack>\r\n\r\n        <Stack\r\n          direction=\"row\"\r\n          justifyContent=\"space-evenly\"\r\n          alignItems=\"center\"\r\n          spacing={5}\r\n        >\r\n          <Rating\r\n            defaultValue=\"1\"\r\n            precision=\".1\"\r\n            size=\"medium\"\r\n            name=\"read-only\"\r\n            value={RatingValue}\r\n            readOnly\r\n          />\r\n          <IconButton onClick={handleCommentClick}>\r\n            <MdOutlineRateReview />\r\n          </IconButton>\r\n        </Stack>\r\n        <Reviews open={openComment} product_id={data.id} />\r\n      </Card>\r\n    </Paper>\r\n  );\r\n};\r\n\r\nexport default Product;\r\n","F:\\Projects under development\\MYAO_project\\myao\\FrontEnd\\src\\components\\Post\\Reviews.js",[],"F:\\Projects under development\\MYAO_project\\myao\\FrontEnd\\src\\components\\Post\\ReportProduct.js",["472","473"],"import * as React from 'react';\r\nimport Box from '@mui/material/Box';\r\nimport {  Button, MenuItem, Modal, Paper, Radio, RadioGroup, Stack, TextField, Typography } from '@mui/material';\r\nimport FormControlLabel from '@mui/material/FormControlLabel';\r\nimport { BsFillArrowRightCircleFill } from \"react-icons/bs\";\r\n\r\nconst ReportProduct = () => {\r\nconst [value, setValue] = React.useState('Controlled');\r\nconst [openReport, setopenReport] = React.useState(0);\r\n\r\n    const stylerep = {\r\n    position: 'absolute',\r\n    top: '50%',\r\n    left: '50%',\r\n    transform: 'translate(-50%, -50%)',\r\n    bgcolor: 'background.paper',\r\n    borderRadius: '16px',\r\n    boxShadow: 50,\r\n    p:1,\r\n    width: {\r\n    xs: \"90%\", \r\n    sm: \"60%\", \r\n    md: \"40%\"\r\n}\r\n  };\r\n\r\n  return (<React.Fragment>\r\n    <MenuItem onClick={ ()=>{setopenReport(1);} } >\r\n    report\r\n    </MenuItem>\r\n<Modal\r\n        open={openReport}\r\n        onClose={ ()=>{ setopenReport(0);} }\r\n      >\r\n        <Paper sx={stylerep} >\r\n\r\n            <Box sx={{ p: 2, borderTop: '3px solid blue' , borderRadius : '16px' }} >\r\n                <Typography align='left' variant='h6' > Report Product </Typography>\r\n            </Box>\r\n            <Typography align='left' variant='caption' sx={{display: { xs: 'block', md: 'none' } }} > Please Choice what is the type of report  </Typography>\r\n            <Typography align='left' variant='h6' sx={{display: { xs: 'none', md: 'block' } }} > Please Choice what is the type of report  </Typography>\r\n\r\n            <Stack \r\n            direction=\"column\"\r\n            justifyContent=\"center\"\r\n            alignItems=\"left\"\r\n            spacing={2}\r\n            sx={{ p: 2, borderBottom: '3px solid blue' , borderRadius : '16px' }}\r\n            >\r\n            <RadioGroup name=\"use-radio-group\" defaultValue=\"first\">\r\n            <FormControlLabel value=\"first\" label=\"first reason\" control={<Radio />} />\r\n            <FormControlLabel value=\"second\" label=\"Second reason\" control={<Radio />} />\r\n            <FormControlLabel value=\"third\" label=\"third reason\" control={<Radio />} />\r\n            <FormControlLabel value=\"Forth\" label=\"forth reason\" control={<Radio />} />\r\n            <FormControlLabel value=\"Fifth\" label=\"Fifth reason\" control={<Radio />} />\r\n            </RadioGroup>\r\n           \r\n            <Stack\r\n            direction=\"row\"\r\n            justifyContent=\"left\"\r\n            alignItems=\"left\"\r\n            spacing={1}\r\n            >\r\n            <TextField\r\n            label=\"Report\"\r\n            placeholder=\"Explain your report\"\r\n            multiline\r\n            variant=\"standard\"\r\n            />\r\n            <Button variant=\"text\" centerRipple size=\"medium\" startIcon={<BsFillArrowRightCircleFill />} />\r\n            </Stack>\r\n\r\n\r\n            </Stack>\r\n\r\n\r\n        </Paper>\r\n\r\n      </Modal>\r\n      </React.Fragment>\r\n  );\r\n}\r\n\r\nexport default ReportProduct;","F:\\Projects under development\\MYAO_project\\myao\\FrontEnd\\src\\pages\\ReportedSurf\\ReportedSurf.js",["474"],"import { Button, Grid, Typography } from \"@mui/material\";\r\nimport axios from \"axios\";\r\nimport { useEffect, useState } from \"react\";\r\nimport SurferCard from \"../../components/surferCard/surferCard\";\r\nimport Wrapper from \"../../components/Wrapper/Wrapper\";\r\nimport useStyle from \"./reportStyle\";\r\nconst ReportedSurf = () => {\r\n  const [rep_sur, set_rep_sur] = useState([]);\r\n  const classes = useStyle();\r\n  useEffect(() => {\r\n    const asyFun = async () => {\r\n      const { data } = await axios.get(\"/api/v1/report/surfer\");\r\n      set_rep_sur([...data.data]);\r\n      //   axios.patch(\"/api/v1/surfer\", {});\r\n    };\r\n    asyFun();\r\n  }, []);\r\n\r\n  const handleBlock = async (ind, element, removed) => {\r\n    try {\r\n      await axios.post(\"/api/v1/report/block\", {\r\n        reported_id: element.reported_id,\r\n        reporter_id: element.reporter_id,\r\n        removed,\r\n      });\r\n      rep_sur.splice(ind, 1);\r\n      set_rep_sur([...rep_sur]);\r\n    } catch (err) {\r\n      alert(err.message);\r\n    }\r\n  };\r\n\r\n  return (\r\n    <Wrapper>\r\n      <Grid container item xs={11} lg={7} md={8} spacing={3}>\r\n        {rep_sur.map((el, ind) => (\r\n          <Grid item sm={4} xs={6} key={el.id}>\r\n            <SurferCard\r\n              user={el}\r\n              id_given={el.reported_id}\r\n              newThings={\r\n                <Grid container justifyContent=\"center\">\r\n                  {/* <Typography variant=\"h5\">\r\n                    {\"Violance and bad words\"}\r\n                  </Typography> */}\r\n                  <Button\r\n                    variant=\"contained\"\r\n                    className={classes.block_sur_button}\r\n                    onClick={() => {\r\n                      handleBlock(ind, el, 1);\r\n                    }}\r\n                  >\r\n                    Block\r\n                  </Button>\r\n                  <Button\r\n                    variant=\"contained\"\r\n                    className={classes.ignore_sur_button}\r\n                    onClick={() => {\r\n                      handleBlock(ind, el, 0);\r\n                    }}\r\n                  >\r\n                    ignore\r\n                  </Button>\r\n                </Grid>\r\n              }\r\n            />\r\n          </Grid>\r\n        ))}\r\n      </Grid>\r\n    </Wrapper>\r\n  );\r\n};\r\nexport default ReportedSurf;\r\n","F:\\Projects under development\\MYAO_project\\myao\\FrontEnd\\src\\pages\\ReportedSurf\\reportStyle.js",[],"F:\\Projects under development\\MYAO_project\\myao\\FrontEnd\\src\\pages\\ReportedSurf\\ReportedMark.js",[],"F:\\Projects under development\\MYAO_project\\myao\\FrontEnd\\src\\components\\surferCard\\marketerCard.js",[],"F:\\Projects under development\\MYAO_project\\myao\\FrontEnd\\src\\pages\\ReportedSurf\\ReportedPosts.js",["475","476"],"import { Button, Grid, Typography } from \"@mui/material\";\r\nimport axios from \"axios\";\r\nimport { useEffect, useState } from \"react\";\r\nimport AdminReportPost from \"../../components/Post/AdminReportPost\";\r\nimport Wrapper from \"../../components/Wrapper/Wrapper\";\r\n// import useStyle from \"./reportStyle\";\r\nconst ReportedPost = () => {\r\n  const [rep_post, set_rep_post] = useState([]);\r\n  const [info, set_info] = useState([]);\r\n  //   const classes = useStyle();\r\n  useEffect(() => {\r\n    const asyFun = async () => {\r\n      const { data } = await axios.get(\"/api/v1/report/post\");\r\n      set_rep_post([...data.data]);\r\n      set_info([...data.reports]);\r\n    };\r\n    asyFun();\r\n  }, []);\r\n\r\n  const handleBlock = async (ind, element, removed) => {\r\n    try {\r\n      await axios.post(\"/api/v1/report/block\", {\r\n        reported_id: info[ind].reported_id,\r\n        reporter_id: info[ind].reporter_id,\r\n        removed,\r\n      });\r\n      rep_post.splice(ind, 1);\r\n      set_rep_post([...rep_post]);\r\n    } catch (err) {\r\n      alert(err.message);\r\n    }\r\n  };\r\n\r\n  return (\r\n    <Wrapper>\r\n      <Grid item xs={11} lg={6} md={8} marginBottom=\"2rem\">\r\n        {rep_post.map((e, i) => (\r\n          <AdminReportPost\r\n            handleBlock={handleBlock}\r\n            key={e.id}\r\n            data={e}\r\n            surfer_info={e.surfer_info}\r\n            style={{ marginTop: \"1rem\" }}\r\n            index={i}\r\n          />\r\n        ))}\r\n      </Grid>\r\n    </Wrapper>\r\n  );\r\n};\r\nexport default ReportedPost;\r\n","F:\\Projects under development\\MYAO_project\\myao\\FrontEnd\\src\\components\\Post\\AdminReportPost.js",[],"F:\\Projects under development\\MYAO_project\\myao\\FrontEnd\\src\