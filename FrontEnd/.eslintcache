\SignStyle.js",[],"E:\\projects\\MYAO_PROJECT\\myao\\FrontEnd\\src\\pages\\Home\\MediumSection.js",[],"E:\\projects\\MYAO_PROJECT\\myao\\FrontEnd\\src\\pages\\Profile\\ProfileStyle.js",[],"E:\\projects\\MYAO_PROJECT\\myao\\FrontEnd\\src\\pages\\Home\\leftSection.js",[],"E:\\projects\\MYAO_PROJECT\\myao\\FrontEnd\\src\\pages\\SettingPage\\settingStyle.js",[],"E:\\projects\\MYAO_PROJECT\\myao\\FrontEnd\\src\\pages\\Profile\\firstSectionButton.js",["127","128"],"import { Button } from \"@mui/material\";\r\nimport axios from \"axios\";\r\nimport { useEffect, useState } from \"react\";\r\nimport { HiUserAdd, HiUserRemove } from \"react-icons/hi\";\r\nimport { MdOutlineReport } from \"react-icons/md\";\r\nimport { FaUserCheck } from \"react-icons/fa\";\r\nimport useStyle from \"./ProfileStyle\";\r\nimport ReportPost from \"../../components/Post/ReportPost\";\r\n\r\nconst FriendSectionButton = ({ source_id, target_id }) => {\r\n  const classes = useStyle();\r\n  const [condition, setCondition] = useState(0);\r\n  // 0 => no relation  // 2 => already a friend  // 4 => sent from // 1 => waiting for accepting\r\n  useEffect(() => {\r\n    const asyncFunc = async () => {\r\n      const { data } = await axios.get(`/api/v1/friend/${target_id}/relation`);\r\n      setCondition(data.data);\r\n    };\r\n    asyncFunc();\r\n  }, [target_id]); // get type of the relation\r\n\r\n  const addFriend = async () => {\r\n    await axios.post(\"/api/v1/friend/requests\", { receiver: target_id });\r\n    setCondition(1);\r\n  };\r\n  const removeFriend = async () => {\r\n    await axios.delete(`/api/v1/friend/${target_id}`);\r\n    setCondition(0);\r\n  };\r\n  const respondRequest = async (accept) => {\r\n    await axios.put(\"/api/v1/friend/requests\", {\r\n      accept,\r\n      sender: target_id,\r\n    });\r\n    console.log(accept);\r\n    accept ? setCondition(2) : setCondition(0);\r\n  };\r\n\r\n  return (\r\n    <>\r\n      {condition === 2 ? (\r\n        <Button\r\n          variant=\"contained\"\r\n          className={classes.AddButton}\r\n          onClick={removeFriend}\r\n        >\r\n          <HiUserRemove style={{ marginRight: \"8px\", fontSize: \"1.2rem\" }} />{\" \"}\r\n          Unfriend\r\n        </Button>\r\n      ) : condition === 4 ? (\r\n        <>\r\n          <Button\r\n            variant=\"contained\"\r\n            className={classes.AddButton}\r\n            onClick={() => respondRequest(1)}\r\n          >\r\n            <FaUserCheck style={{ marginRight: \"8px\", fontSize: \"1.2rem\" }} />\r\n            Confirm Request\r\n          </Button>\r\n          <Button\r\n            variant=\"contained\"\r\n            className={classes.AddButton}\r\n            onClick={() => respondRequest(0)}\r\n          >\r\n            <FaUserCheck style={{ marginRight: \"8px\", fontSize: \"1.2rem\" }} />\r\n            unaccept\r\n          </Button>\r\n        </>\r\n      ) : condition === 1 ? (\r\n        <Button\r\n          variant=\"contained\"\r\n          className={classes.AddButton}\r\n          onClick={() => respondRequest(0)}\r\n        >\r\n          <HiUserRemove style={{ marginRight: \"6px\", fontSize: \"1.2rem\" }} />\r\n          Undo Requesting\r\n        </Button>\r\n      ) : (\r\n        <Button\r\n          variant=\"contained\"\r\n          className={classes.AddButton}\r\n          onClick={addFriend}\r\n        >\r\n          <HiUserAdd style={{ marginRight: \"6px\", fontSize: \"1.2rem\" }} /> Add\r\n          Friend\r\n        </Button>\r\n      )}\r\n      {/* <ReportPost\r\n        is_post={0}\r\n        reported_id={target_id}\r\n        myButton={\r\n          <Button\r\n            variant=\"outlined\"\r\n            className={`${classes.AddButton} ${classes.reportButton}`}\r\n          >\r\n            <MdOutlineReport style={{ fontSize: \"1.3rem\" }} />\r\n            Report\r\n          </Button>\r\n        }\r\n      ></ReportPost> */}\r\n    </>\r\n  );\r\n};\r\nexport default FriendSectionButton;\r\n","E:\\projects\\MYAO_PROJECT\\myao\\FrontEnd\\src\\components\\Header\\HeaderStyle.js",[],"E:\\projects\\MYAO_PROJECT\\myao\\FrontEnd\\src\\components\\Header\\tabs.js",[],"E:\\projects\\MYAO_PROJECT\\myao\\FrontEnd\\src\\components\\InputField.js\\InputField.js",[],"E:\\projects\\MYAO_PROJECT\\myao\\FrontEnd\\src\\components\\AvatarImage\\AvatarImage.js",[],"E:\\projects\\MYAO_PROJECT\\myao\\FrontEnd\\src\\pages\\Home\\HomeStyle.js",[],"E:\\projects\\MYAO_PROJECT\\myao\\FrontEnd\\src\\components\\userCard\\userCard.js",[],"E:\\projects\\MYAO_PROJECT\\myao\\FrontEnd\\src\\components\\Post\\Create_post.js",[],"E:\\projects\\MYAO_PROJECT\\myao\\FrontEnd\\src\\components\\Post\\ReportPost.js",[],"E:\\projects\\MYAO_PROJECT\\myao\\FrontEnd\\src\\components\\AvatarImage\\AvatarStyle.js",[],"E:\\projects\\MYAO_PROJECT\\myao\\FrontEnd\\src\\components\\Post\\PopPostStyle.js",[],"E:\\projects\\MYAO_PROJECT\\myao\\FrontEnd\\src\\components\\Post\\PostButton.js",[],"E:\\projects\\MYAO_PROJECT\\myao\\FrontEnd\\src\\components\\Post\\UploadButton.js",[],{"ruleId":"129","severity":1,"message":"130","line":5,"column":10,"nodeType":"131","messageId":"132","endLine":5,"endColumn":25},{"ruleId":"129","severity":1,"message":"133","line":8,"column":8,"nodeType":"131","messageId":"132","endLine":8,"endColumn":18},"no-unused-vars","'MdOutlineReport' is defined but never used.","Identifier","unusedVar","'ReportPost' is defined but never used."]