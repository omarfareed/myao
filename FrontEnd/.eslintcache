 margin: \"0px\",\r\n          }}\r\n        >\r\n          <img src={photos[0].img} alt={photos[0].title} onClick={handleOpen} />\r\n        </ImageListItem>\r\n        <ImageListItem rows={1} cols={2} sx={{}}>\r\n          <img src={photos[1].img} alt={photos[1].title} onClick={handleOpen} />\r\n        </ImageListItem>\r\n        <ImageListItem rows={1} cols={3} sx={{ height: \"150%\" }}>\r\n          <img src={photos[2].img} alt={photos[2].title} onClick={handleOpen} />\r\n          <ImageListItemBar\r\n            position=\"top\"\r\n            sx={{ height: \"100%\" }}\r\n            actionIcon={\r\n              <IconButton\r\n                sx={{\r\n                  position: \"absolute\",\r\n                  top: \"50%\",\r\n                  left: \"50%\",\r\n                  transform: \"translate(-50%, -50%)\",\r\n                  color: \"#fff\",\r\n                }}\r\n                onClick={handleOpen}\r\n              >\r\n                <AiOutlinePlusCircle />\r\n              </IconButton>\r\n            }\r\n          />\r\n        </ImageListItem>\r\n      </ImageList>\r\n    );\r\n\r\n  if (photolength == 3)\r\n    imgs = (\r\n      <ImageList\r\n        gap={1}\r\n        rowHeight={121}\r\n        variant=\"quilted\"\r\n        sx={{ width: \"100%\", height: \"auto\", overflow: \"hidden\" }}\r\n        cols={3}\r\n      >\r\n        <ImageListItem\r\n          rows={2}\r\n          cols={5}\r\n          sx={{ transform: \"scale(1,.8)\", margin: \"0px\" }}\r\n        >\r\n          <img src={photos[0].img} alt={photos[0].title} onClick={handleOpen} />\r\n        </ImageListItem>\r\n        <ImageListItem rows={1} cols={2} sx={{ transform: \"scale(1,.8)\" }}>\r\n          <img src={photos[1].img} alt={photos[1].title} onClick={handleOpen} />\r\n        </ImageListItem>\r\n        <ImageListItem\r\n          rows={1}\r\n          cols={3}\r\n          sx={{ transform: \"scale(1,.8)\", height: \"150%\" }}\r\n        >\r\n          <img src={photos[2].img} alt={photos[2].title} onClick={handleOpen} />\r\n        </ImageListItem>\r\n      </ImageList>\r\n    );\r\n\r\n  if (photolength == 2)\r\n    imgs = (\r\n      <ImageList\r\n        gap={1}\r\n        rowHeight={121}\r\n        variant=\"quilted\"\r\n        sx={{ width: \"100%\", height: \"auto\", overflow: \"hidden\" }}\r\n        cols={1}\r\n      >\r\n        <ImageListItem cols={2} sx={{ transform: \"scale(1,1.2)\" }}>\r\n          <img src={photos[0].img} alt={photos[0].title} onClick={handleOpen} />\r\n        </ImageListItem>\r\n        <ImageListItem cols={2} sx={{ transform: \"scale(1,.8)\" }}>\r\n          <img src={photos[1].img} alt={photos[1].title} onClick={handleOpen} />\r\n        </ImageListItem>\r\n      </ImageList>\r\n    );\r\n\r\n  if (photolength == 1)\r\n    imgs = (\r\n      <ImageList\r\n        gap={1}\r\n        rowHeight={121}\r\n        variant=\"quilted\"\r\n        sx={{ width: \"100%\", height: \"auto\", overflow: \"hidden\" }}\r\n        cols={1}\r\n      >\r\n        <ImageListItem rows={2} cols={2} sx={{ transform: \"scale(1,1.2)\" }}>\r\n          <img src={photos[0].img} alt={photos[0].title} onClick={handleOpen} />\r\n        </ImageListItem>\r\n      </ImageList>\r\n    );\r\n\r\n  return (\r\n    <>\r\n      {imgs}\r\n      <Modal open={open} onClose={handleClose}>\r\n        <ImageSlider SliderData={photos} currentimg={imgIndex} />\r\n      </Modal>\r\n    </>\r\n  );\r\n};\r\n\r\nexport default PostImgs;\r\n","F:\\Projects under development\\MYAO_project\\myao\\FrontEnd\\src\\components\\Post\\Comments.js",[],"F:\\Projects under development\\MYAO_project\\myao\\FrontEnd\\src\\components\\Post\\ReportPost.js",["450","451"],"F:\\Projects under development\\MYAO_project\\myao\\FrontEnd\\src\\components\\Post\\PostContent.js",[],"F:\\Projects under development\\MYAO_project\\myao\\FrontEnd\\src\\components\\Post\\ImgSlider.js",["452"],"import { Box, ImageListItem } from '@mui/material';\r\nimport React, { useState } from 'react';\r\nimport { FaArrowAltCircleRight, FaArrowAltCircleLeft } from 'react-icons/fa';\r\nimport {slider,image,right_arrow,left_arrow,slide as s,slide_active} from \"./imgSliderStyles.js\"\r\n\r\nconst ImageSlider = ({ SliderData, currentimg }) => {\r\n\r\n  const [current, setCurrent] = useState(currentimg);\r\n  const length = SliderData.length;\r\n\r\n  const nextSlide = () => {\r\n    setCurrent(current === length - 1 ? 0 : current + 1);\r\n  };\r\n\r\n  const prevSlide = () => {\r\n    setCurrent(current === 0 ? length - 1 : current - 1);\r\n  };\r\n\r\n  if (!Array.isArray(SliderData) || SliderData.length <= 0) {\r\n    return null;\r\n  }\r\n\r\n  return (\r\n    <Box sx={slider} >\r\n      <Box sx={left_arrow}><FaArrowAltCircleLeft  onClick={prevSlide} /></Box>\r\n      <Box sx={right_arrow} ><FaArrowAltCircleRight  onClick={nextSlide} /></Box>\r\n      {SliderData.map((slide, index) => {\r\n        return (\r\n          <Box\r\n            sx={index === current ? slide_active : s}\r\n            key={index}\r\n          >\r\n            {index === current && (\r\n                <ImageListItem sx={image} >\r\n              <img src={slide.img} alt='travel image'   />\r\n              </ImageListItem>\r\n            )}\r\n          </Box>\r\n        );\r\n      })}\r\n    </Box>\r\n  );\r\n};\r\n\r\nexport default ImageSlider;","F:\\Projects under development\\MYAO_project\\myao\\FrontEnd\\src\\components\\Post\\imgSliderStyles.js",[],"F:\\Projects under development\\MYAO_project\\myao\\FrontEnd\\src\\components\\Wrapper\\Wrapper.js",[],"F:\\Projects under development\\MYAO_project\\myao\\FrontEnd\\src\\pages\\FriendRequests\\FriendRequestPage.js",[],"F:\\Projects under development\\MYAO_project\\myao\\FrontEnd\\src\\pages\\Profile\\firstSectionButton.js",[],"F:\\Projects under development\\MYAO_project\\myao\\FrontEnd\\src\\components\\emptyScreen\\NoFriendReq.js",[],"F:\\Projects under development\\MYAO_project\\myao\\FrontEnd\\src\\page